# ─────────────────────────────────────────────
# AWS 공통
# ─────────────────────────────────────────────
AWS_REGION=ap-northeast-2

# ─────────────────────────────────────────────
# Cognito (prod 필수 — 미설정 시 JWT 검증 불가)
# ─────────────────────────────────────────────
COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXXX

# ─────────────────────────────────────────────
# DynamoDB
# - 로컬(DynamoDB Local): http://localhost:8000
# - prod(VPC Gateway Endpoint 포함): 비워두면 SDK가 표준 리전 엔드포인트 사용
#   VPC Gateway Endpoint는 라우팅 테이블에서 처리되므로 별도 설정 불필요
# ─────────────────────────────────────────────
DYNAMODB_ENDPOINT=http://localhost:8000

TABLE_USER=chattr-dev-user
TABLE_WORKSPACE=chattr-dev-workspace
TABLE_WORKSPACE_MEMBER=chattr-dev-workspace-member
TABLE_CHANNEL=chattr-dev-channel
TABLE_CHANNEL_MEMBER=chattr-dev-channel-member
TABLE_DM=chattr-dev-dm
TABLE_MESSAGE=chattr-dev-message
TABLE_DEVICE=chattr-dev-device

# ─────────────────────────────────────────────
# S3 (파일 업로드 / Presigned URL)
# - 로컬(MinIO): http://localhost:9000
# - prod(VPC Gateway Endpoint 포함): 비워두면 SDK가 표준 리전 엔드포인트 사용
#   VPC Gateway Endpoint는 라우팅 테이블에서 처리되므로 별도 설정 불필요
# ─────────────────────────────────────────────
S3_BUCKET=chattr-dev-files
S3_PRESIGN_EXPIRY_MINUTES=10
S3_ENDPOINT=http://localhost:9000
